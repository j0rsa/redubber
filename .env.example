# =============================================================================
# Redubber v2.0 Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# =============================================================================
# OpenAI Configuration (REQUIRED)
# =============================================================================
# Your OpenAI API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# GPT model for translation (default: gpt-4o)
# Options: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o

# TTS voice for audio generation (default: nova)
# Options: alloy, echo, fable, onyx, nova, shimmer
OPENAI_VOICE=nova

# =============================================================================
# Task Queue Configuration
# =============================================================================
# Maximum number of concurrent video redubbing tasks (default: 1)
# Higher values increase throughput but consume more resources
MAX_CONCURRENT_REDUBS=1

# Maximum number of tasks in the queue (default: 100)
TASK_QUEUE_MAX_SIZE=100

# Maximum concurrent TTS API calls (default: 100)
# OpenAI allows high concurrency for TTS endpoints
TTS_MAX_CONCURRENT=100

# =============================================================================
# Storage Configuration
# =============================================================================
# For LOCAL DEVELOPMENT (relative paths):
DATABASE_URL=./redubber.db
TMP_DIR=./redubber_tmp
MOUNTED_STORAGE=./storage

# For DOCKER PRODUCTION (absolute paths - uncomment and comment above):
# DATABASE_URL=/mounted-storage/redubber.db
# TMP_DIR=/tmp/redubber
# MOUNTED_STORAGE=/mounted-storage

# =============================================================================
# API Configuration
# =============================================================================
# API metadata
API_TITLE=Redubber API
API_VERSION=2.0.0

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level (default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# CORS Configuration
# =============================================================================
# Comma-separated list of allowed origins for CORS
# Local development includes common Vite ports
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:4173

# =============================================================================
# Docker-specific Configuration
# =============================================================================
# These are set by docker-compose.yml and typically don't need to be changed
# Uncomment only if running outside Docker

# Host to bind to (default: 0.0.0.0 in Docker, 127.0.0.1 for local dev)
# HOST=0.0.0.0

# Port to listen on (default: 8000)
# PORT=8000

# Number of uvicorn workers (default: 1)
# Higher values can improve throughput but increase memory usage
# WORKERS=1
